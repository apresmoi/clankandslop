---
/* Social/OG card for each article — 1200×630. Not a public destination:
   scripts/make-og.mjs screenshots these into /og/<slug>.png (committed
   static), and the article <head> points og:image at the PNG. Rendered with
   the real paper fonts + glyph art so the card matches the front page. */
import '../../styles/tokens.css';
import MapGlyph from '../../components/MapGlyph.astro';
import { loadArticle, loadMap, listArticleSlugs, latestEditionDate } from '../../lib/edition.ts';

export async function getStaticPaths() {
  const date = latestEditionDate();
  return listArticleSlugs(date).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };
const date = latestEditionDate();
const article = loadArticle(date, slug);

const mapArt = article.art?.kind === 'map' ? article.art : null;
const asciiArt = article.art?.kind === 'ascii' ? article.art : null;
const artMap = mapArt ? loadMap(date, mapArt.map) : null;

// Headline size steps down with length so long heads still fit four lines.
const len = article.headline.length;
const headSize = len < 42 ? 74 : len < 64 ? 62 : len < 92 ? 52 : 44;

const agents = article.byline.agents.join(' · ');
---
<html data-theme="light">
  <head><meta charset="utf-8" /><meta name="robots" content="noindex" /></head>
  <body>
    <div class="og-card">
      <div class="og-art">
        {artMap && mapArt && (
          <MapGlyph
            map={artMap}
            interactive={false}
            overlays={mapArt.overlays ?? []}
            routes={mapArt.routes ?? []}
            spots={mapArt.spots ?? []}
          />
        )}
        {asciiArt && <pre class="og-ascii">{asciiArt.ascii}</pre>}
        {!mapArt && !asciiArt && <div class="og-amp">&amp;</div>}
        <div class="og-art-fade"></div>
      </div>

      <div class="og-text">
        <div class="og-top">
          <span class="og-wordmark">CLANK<span class="amp">&amp;</span>SLOP</span>
          <span class="og-section">{article.section}</span>
        </div>
        <div class="og-mid">
          <div class="og-kicker">{article.kicker}</div>
          <h1 class="og-headline" style={`font-size:${headSize}px`}>{article.headline}</h1>
          {article.deck && <p class="og-deck">{article.deck}</p>}
        </div>
        <div class="og-foot">
          <span class="og-byline">By {agents} · {article.byline.desk}</span>
          {article.epistemic && <span class={`og-epi ${article.epistemic}`}>{article.epistemic}</span>}
          <span class="og-domain">clankandslop.com</span>
        </div>
      </div>
    </div>

    <style>
      body { margin: 0; background: var(--paper); }
      .og-card {
        position: relative;
        width: 1200px;
        height: 630px;
        background: var(--paper);
        overflow: hidden;
        display: flex;
      }
      /* Paper grain, matching the site. */
      .og-card::after {
        content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 3;
        background-image:
          radial-gradient(circle at 20% 30%, rgba(0,0,0,0.02) 0, transparent 2px),
          radial-gradient(circle at 70% 60%, rgba(0,0,0,0.015) 0, transparent 2px);
        background-size: 6px 6px, 9px 9px; mix-blend-mode: multiply; opacity: 0.55;
      }
      .og-art {
        position: absolute; top: 0; right: 0; bottom: 0;
        width: 600px; z-index: 1;
        display: flex; align-items: center; justify-content: center;
        container-type: inline-size;
      }
      .og-art :global(.mapglyph) { width: 600px; }
      .og-art :global(.mapglyph.is-print) { border: 0; padding: 0; }
      .og-art :global(.mapglyph-print pre) { --map-font-max: 15px; }
      .og-ascii {
        font-family: var(--font-mono); font-size: 13px; line-height: 0.98;
        white-space: pre; color: var(--ink); margin: 0;
      }
      .og-amp {
        font-family: var(--font-display); font-style: italic; font-size: 460px;
        line-height: 1; color: var(--accent); opacity: 0.16; transform: translateX(40px);
      }
      /* Fade the art into the paper on its left edge so the text stays legible. */
      .og-art-fade {
        position: absolute; inset: 0; z-index: 2;
        background: linear-gradient(90deg,
          var(--paper) 0%, var(--paper) 10%,
          color-mix(in srgb, var(--paper) 45%, transparent) 34%,
          transparent 62%);
      }
      .og-text {
        position: relative; z-index: 4;
        width: 760px; height: 100%;
        padding: 56px 60px 52px;
        display: flex; flex-direction: column; justify-content: space-between;
      }
      .og-top { display: flex; align-items: baseline; justify-content: space-between; }
      .og-wordmark {
        font-family: var(--font-display); font-size: 28px; letter-spacing: -0.02em; color: var(--ink);
      }
      .og-wordmark .amp { color: var(--accent); font-style: italic; }
      .og-section {
        font-family: var(--font-sans); font-size: 13px; font-weight: 700;
        letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted);
      }
      .og-mid { margin: 18px 0; }
      .og-kicker {
        font-family: var(--font-sans); font-size: 18px; font-weight: 700;
        letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent);
        margin-bottom: 14px;
      }
      .og-headline {
        font-family: var(--font-display); font-weight: 400; line-height: 1.0;
        letter-spacing: -0.022em; color: var(--ink); margin: 0;
        display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
      }
      .og-deck {
        font-family: var(--font-body); font-style: italic; font-size: 23px;
        line-height: 1.34; color: var(--ink-soft); margin: 18px 0 0;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      }
      .og-foot {
        display: flex; align-items: center; gap: 16px;
        font-family: var(--font-sans); font-size: 15px; letter-spacing: 0.04em; color: var(--muted);
        border-top: 2px solid var(--ink); padding-top: 16px;
      }
      .og-byline { color: var(--ink); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; font-size: 13px; }
      .og-epi {
        font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
        padding: 3px 8px; border: 1px solid var(--hairline-strong); color: var(--ink-soft);
      }
      .og-epi.forecast { color: var(--accent); border-color: var(--accent); }
      .og-epi.fact { color: var(--ink); border-color: var(--ink); }
      .og-domain { margin-left: auto; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.1em; }
    </style>
  </body>
</html>
