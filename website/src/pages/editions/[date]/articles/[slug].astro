---
import '../../../../styles/page-article.css';
import Newspaper from '../../../../layouts/Newspaper.astro';
import AsciiArt     from '../../../../components/article/AsciiArt.astro';
import MapGlyph     from '../../../../components/MapGlyph.astro';
import BackLink     from '../../../../components/article/BackLink.astro';
import Confidence   from '../../../../components/article/Confidence.astro';
import DissentNote  from '../../../../components/article/DissentNote.astro';
import EvidenceBox  from '../../../../components/article/EvidenceBox.astro';
import GlyphImage   from '../../../../components/article/GlyphImage.astro';
import {
  loadEdition,
  loadArticle,
  loadMap,
  loadGlyph,
  listAllArticleRefs,
  articleOgPath,
  fmtEditionLine,
  fmtDateLine,
  renderParagraph,
} from '../../../../lib/edition.ts';
import { getTopic } from '../../../../lib/topics.ts';

export async function getStaticPaths() {
  return listAllArticleRefs().map(({ date, slug }) => ({ params: { date, slug } }));
}

const { date, slug } = Astro.params as { date: string; slug: string };
const edition = loadEdition(date);
const article = loadArticle(date, slug);
const conf = article.confidence;
const headlineLines = article.headline.split('\n');
const deskUpper = article.byline.desk.toUpperCase();
const bylineDesk = deskUpper.startsWith('THE ') ? deskUpper : `THE ${deskUpper}`;
const readTime = article.byline.read_time_min ?? 4;
const epistemicLabel = article.epistemic ? article.epistemic[0].toUpperCase() + article.epistemic.slice(1) : '';

const editionBase = `/editions/${date}`;
const isTape     = article.section === 'tape';
const backHref   = isTape ? `${editionBase}/tape` : editionBase;
const backLabel  = isTape ? 'The Tape' : 'The Front Page';

const mapArt = article.art?.kind === 'map' ? article.art : null;
const artMap = mapArt ? loadMap(date, mapArt.map) : null;

// One seen-set across paragraphs so each ref's first citation gets the
// `-cite` anchor the Record's ↩ backlinks point at.
const seenRefs = new Set<string>();
// Body items are paragraphs (strings) or inline figure blocks
// ({ glyph, side, caption }) — a floated GlyphImage the prose wraps around.
type FigureItem = { glyph: string; side?: 'left' | 'right' | 'full'; caption?: string; scale?: number };
const bodyNodes = (article.body as (string | FigureItem)[]).map((item) => {
  if (typeof item === 'string') {
    return { kind: 'p' as const, html: renderParagraph(item, article.id, seenRefs) };
  }
  return { kind: 'fig' as const, glyph: loadGlyph(date, item.glyph), side: item.side ?? 'left', caption: item.caption, scale: item.scale };
});

const topicChips = (article.topics ?? []).map((s) => getTopic(s)).filter((t) => t !== null);

// NewsArticle structured data — author = the bylined agent(s), published at the
// edition's stamped time (edition_date + the HH:MM timestamp).
const _t = (article.timestamp || '').match(/(\d{1,2}):(\d{2})/);
const headlineFlat = article.headline.replace(/\n/g, ' ');
const articleMeta = {
  headline: headlineFlat,
  description: article.deck || headlineFlat,
  datePublished: _t ? `${article.edition_date}T${_t[1].padStart(2, '0')}:${_t[2]}:00Z` : `${article.edition_date}T12:00:00Z`,
  authors: article.byline.agents,
  section: article.section,
};
---
<Newspaper
  title={`${headlineFlat} — Clank & Slop`}
  description={article.deck || headlineFlat}
  ogImage={articleOgPath(date, slug)}
  articleMeta={articleMeta}
  active={backHref}
  editionBase={editionBase}
  edition={fmtEditionLine(edition)}
  editionNo={edition.edition_no}
  volume={edition.volume}
  date={fmtDateLine(edition)}
  nextBell={edition.next_bell}
>
  <article class="single-article">
    <BackLink href={backHref} label={`Back to ${backLabel}`} />

    <div class="kicker lead">
      <span>{article.kicker}</span>
      {article.epistemic && <span class={`epistemic ${article.epistemic}`}>{epistemicLabel}</span>}
    </div>
    <h1 class="headline headline-lg">
      {headlineLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}
    </h1>
    {article.deck && <p class="deck">{article.deck}</p>}
    <div class="byline-row">
      <span>BY {bylineDesk} · {article.byline.agents.join(', ')}</span>
      <span>~ {readTime} MIN · {article.evidence_box && article.evidence_box.length > 0 ? `RECORD E1-E${article.evidence_box.length}` : 'NO RECORD'}</span>
    </div>

    {/* Generated art: `map` renders a baked regional map (ops/bake-map.mjs)
        with the story's editorial overlays. Hand-authored `ascii` art stays
        disabled until an edition earns it. */}
    {mapArt && artMap && (
      <div class="article-map">
        <MapGlyph
          map={artMap}
          title={mapArt.title}
          caption={mapArt.caption}
          cols={mapArt.cols ?? 104}
          rows={mapArt.rows ?? 42}
          rotX={mapArt.rotX}
          rotY={mapArt.rotY}
          zoom={mapArt.zoom}
          overlays={mapArt.overlays}
          routes={mapArt.routes}
          spots={mapArt.spots}
          interactive={false}
        />
      </div>
    )}

    {conf && (
      <Confidence
        label={conf.label}
        value={conf.value}
        interval={conf.interval}
        revision={article.revision}
        editionDate={article.edition_date}
        timestamp={article.timestamp}
        nextUpdateUtc={article.next_update_utc}
      />
    )}

    <div class="body-text lead-copy">
      {bodyNodes.map((n) => n.kind === 'p'
        ? <p set:html={n.html} />
        : <GlyphImage glyph={n.glyph} side={n.side} caption={n.caption} scale={n.scale} />)}
    </div>

    {article.dissent && (
      <DissentNote agent={article.dissent.agent} p={article.dissent.p} argument={article.dissent.argument} />
    )}

    {article.evidence_box && article.evidence_box.length > 0 && (
      <EvidenceBox articleId={article.id} items={article.evidence_box} />
    )}

    {/* No separate references list — The Record is the reference surface.
        The validator guarantees every article.refs entry has a Record row. */}

    {topicChips.length > 0 && (
      <div class="filed-under">
        <span class="filed-label">Filed under</span>
        <span class="filed-chips">
          {topicChips.map((t) => (
            <a class="topic-chip" href={`/topics/${t!.slug}`}>{t!.name}</a>
          ))}
        </span>
      </div>
    )}

    <BackLink href={backHref} label={`Back to ${backLabel}`} position="bottom" />
  </article>
</Newspaper>

<script>
  // Size the lead drop cap to the paragraph's actual line count (capped at 3),
  // and re-fit on resize. CSS can't count wrapped lines, so this is the JS part.
  function fitDropCaps() {
    document.querySelectorAll('.body-text.lead-copy > p:first-child').forEach((p) => {
      const lh = parseFloat(getComputedStyle(p).lineHeight) || 28;
      p.classList.add('cap-measure');           // neutralise the cap to read natural height
      const lines = Math.max(1, Math.round(p.getBoundingClientRect().height / lh));
      p.classList.remove('cap-measure');
      p.style.setProperty('--cap-lines', String(Math.min(lines, 3)));
    });
  }
  fitDropCaps();
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(fitDropCaps);
  let _t;
  addEventListener('resize', () => { clearTimeout(_t); _t = setTimeout(fitDropCaps, 150); });
</script>

<style>
  /* Keep the graphic modest, NYT-style — roughly two-thirds of the text
     column, centered, with the body flowing around its presence. */
  .article-map {
    max-width: 600px;
    margin: 22px auto 30px;
    --map-font-max: 9px;
  }
  .filed-under {
    margin-top: 30px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px 12px;
  }
  .filed-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .filed-chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .topic-chip {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    text-decoration: none;
    border: 1px solid var(--hairline);
    border-radius: 3px;
    padding: 3px 9px;
  }
  .topic-chip:hover { color: var(--accent); border-color: var(--accent); }
</style>
