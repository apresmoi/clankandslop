---
/** The World Desk globe — ETOPO1-derived land quads rendered as a rotating
    ASCII sphere by glyphcss. Plain-text output (no color spans) so the glyph
    ramp inherits the paper's ink color in both themes. */
interface Hotspot {
  name: string;
  lat: number;
  lon: number;
  /** Live posterior shown on the marker, e.g. 0.34. */
  p?: number;
}
interface Props {
  caption?: string;
  /** World-desk numbers — when present (hydrated from edition chrome via
      `"worldDesk": "edition"` in page JSON), the caption is derived from
      them rather than hand-typed. */
  worldDesk?: { escalation_index: number; delta: string; open_conflicts: number; watch: number };
  cols?: number;
  rows?: number;
  /** Degrees of latitude/longitude per land quad. */
  stepDeg?: number;
  /** Initial camera angles (radians). */
  rotX?: number;
  rotY?: number;
  hotspots?: Hotspot[];
}
const { caption: rawCaption = '', worldDesk, cols = 64, rows = 30, stepDeg = 5, rotX = 0.35, rotY = 2.1, hotspots = [] } = Astro.props;
const caption = worldDesk
  ? `The World Desk · escalation ${worldDesk.escalation_index.toFixed(2)} ${worldDesk.delta} · ${worldDesk.open_conflicts} open conflicts · ${worldDesk.watch} on watch · drag to rotate`
  : rawCaption;
const config = JSON.stringify({ cols, rows, stepDeg, rotX, rotY, hotspots });
---
<figure class="worldglyph">
  <div class="worldglyph-stage" data-worldglyph-stage>
    <div class="worldglyph-host" data-worldglyph data-config={config}></div>
  </div>
  {caption && <figcaption class="worldglyph-caption">{caption}</figcaption>}
</figure>

<script>
  import { createGlyphScene, createGlyphOrbitControls, createGlyphPerspectiveCamera } from 'glyphcss';
  import landmask from '../data/landmask.json';

  const D = Math.PI / 180;
  // Z-up, X-right, +Y sin(lon) — a right-handed Earth, east CCW from the pole.
  // Correct at every drag angle; the quad winding below (not the camera) is
  // what keeps it unmirrored.
  const toVec3 = (lat: number, lon: number, r = 1): [number, number, number] => [
    r * Math.cos(lat * D) * Math.cos(lon * D),
    r * Math.cos(lat * D) * Math.sin(lon * D),
    r * Math.sin(lat * D),
  ];

  const isLand = (lat: number, lon: number): boolean => {
    const row = Math.min(landmask.rows - 1, Math.max(0, Math.floor(90 - lat)));
    const col = ((Math.floor(lon + 180) % 360) + 360) % 360;
    return landmask.mask[row][col] === '1';
  };

  function landFraction(lat: number, lon: number, step: number): number {
    let land = 0, total = 0;
    for (let dlat = 0.5; dlat < step; dlat++)
      for (let dlon = 0.5; dlon < step; dlon++) {
        if (isLand(lat + dlat, lon + dlon)) land++;
        total++;
      }
    return land / total;
  }

  // Land/ocean contrast comes from span colors (the plain-text glyph ramp is
  // lighting-only, so monochrome output can't separate them). Colors are read
  // from the theme's CSS variables; the scene re-inits on theme flips.
  const parseHex = (hex: string): [number, number, number] => {
    const h = hex.trim().replace('#', '');
    const v = h.length === 3 ? h.split('').map((c) => c + c).join('') : h;
    return [parseInt(v.slice(0, 2), 16), parseInt(v.slice(2, 4), 16), parseInt(v.slice(4, 6), 16)];
  };
  const mix = (a: string, b: string, t: number): string => {
    const [ar, ag, ab] = parseHex(a);
    const [br, bg, bb] = parseHex(b);
    const c = (x: number, y: number) => Math.round(x + (y - x) * t).toString(16).padStart(2, '0');
    return `#${c(ar, br)}${c(ag, bg)}${c(ab, bb)}`;
  };

  // One quad per cell, wound SW→SE→NE→NW so its screen-space winding is
  // front-facing under glyphcss's backface cull — otherwise the cull keeps the
  // far hemisphere and the globe renders mirrored (Africa left of South
  // America). Ocean cells are a faint paper-ink blend (gives the sphere its
  // disc silhouette); land is full ink.
  function buildGlobePolygons(step: number, land: string, ocean: string) {
    const polygons = [];
    for (let lat = -90; lat < 90; lat += step)
      for (let lon = -180; lon < 180; lon += step) {
        const color = landFraction(lat, lon, step) >= 0.3 ? land : ocean;
        polygons.push({
          vertices: [
            toVec3(lat, lon),
            toVec3(lat, lon + step),
            toVec3(lat + step, lon + step),
            toVec3(lat + step, lon),
          ],
          color,
        });
      }
    return polygons;
  }

  const scenes = new Map<HTMLElement, { destroy(): void }>();

  function initGlobe(host: HTMLElement) {
    scenes.get(host)?.destroy();
    host.innerHTML = '';
    const cfg = JSON.parse(host.dataset.config!);
    const css = getComputedStyle(document.documentElement);
    const ink = css.getPropertyValue('--ink').trim() || '#0F0F0F';
    const paper = css.getPropertyValue('--paper').trim() || '#F4EEE0';
    // The library's default camera (distance 3) renders nothing — always
    // pass an explicit far camera, like the upstream examples do.
    const camera = createGlyphPerspectiveCamera({ rotX: cfg.rotX, rotY: cfg.rotY, zoom: 0.33, distance: 100 });
    const scene = createGlyphScene(host, {
      mode: 'solid',
      cols: cfg.cols,
      rows: cfg.rows,
      cellAspect: 1.67,
      useColors: true,
      camera,
      // Glyph density encodes lighting only (color never reaches the ramp),
      // so keep lighting nearly flat — land/ocean separation must come from
      // span color, and a strong directional gradient reads as fake geography.
      directionalLight: { direction: [-0.5, -1, 0.4], intensity: 0.2 },
      ambientLight: { intensity: 0.85 },
    });
    scene.add(buildGlobePolygons(cfg.stepDeg, ink, mix(paper, ink, 0.13)));
    // Markers are numbered ①② … to key against the flashpoint index that
    // runs beside the globe (WorldIndex block).
    const CIRCLED = '①②③④⑤⑥⑦⑧⑨';
    const marks: Array<{ el: HTMLElement; lat: number; lon: number }> = [];
    (cfg.hotspots ?? []).forEach((h: any, i: number) => {
      const label = `${CIRCLED[i] ?? '◉'} ${h.name}${typeof h.p === 'number' ? ` · p ${h.p.toFixed(2)}` : ''}`;
      const spot = scene.addHotspot({
        id: h.name,
        at: toVec3(h.lat, h.lon, 1.04),
        size: [label.length + 2, 1],
      });
      spot.el.classList.add('worldglyph-spot');
      spot.el.textContent = label;
      marks.push({ el: spot.el, lat: h.lat, lon: h.lon });
    });

    // glyphcss only culls hotspots that fall off-screen, not ones that rotate
    // to the far side of the sphere — so without this the back markers show
    // through the globe. Hide a label once its point faces away from the
    // camera. Recompute only when the camera moves, so a still globe is free.
    const camDepth = (lat: number, lon: number): number => {
      const cl = Math.cos(lat * D), x = cl * Math.cos(lon * D), y = cl * Math.sin(lon * D), z = Math.sin(lat * D);
      const i = Math.sin(camera.rotY) * y + Math.cos(camera.rotY) * x;
      return Math.sin(camera.rotX) * i + Math.cos(camera.rotX) * z;
    };
    let lastY: number | null = null, lastX: number | null = null, raf = 0;
    const cull = () => {
      if (camera.rotY !== lastY || camera.rotX !== lastX) {
        lastY = camera.rotY; lastX = camera.rotX;
        for (const m of marks) {
          const front = camDepth(m.lat, m.lon) > 0.04;
          m.el.style.opacity = front ? '1' : '0';
          m.el.style.pointerEvents = front ? '' : 'none';
        }
      }
      raf = requestAnimationFrame(cull);
    };
    cull();

    // Natural drag (invert: -1 spun it backwards) + a slow idle spin that
    // pauses while you drag. Respect reduced-motion, and stop the spin when the
    // globe scrolls out of view so it isn't re-rasterizing off-screen.
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const controls = createGlyphOrbitControls(scene, {
      drag: true,
      wheel: false,
      invert: 1,
      animate: reduceMotion ? false : { speed: 0.28, axis: 'y', pauseOnInteraction: true },
    });
    let io: IntersectionObserver | null = null;
    if (!reduceMotion && 'IntersectionObserver' in window) {
      io = new IntersectionObserver(([e]) => { e.isIntersecting ? controls.resume() : controls.pause(); }, { threshold: 0 });
      io.observe(host);
    }
    scenes.set(host, { destroy: () => { io?.disconnect(); cancelAnimationFrame(raf); controls.destroy(); scene.destroy(); } });
    // The globe is sized for a wide desktop column; its eastern hotspot labels
    // run off narrow screens. Scale the whole host (sphere + labels together,
    // so alignment is preserved) down to the container, then re-center.
    requestAnimationFrame(() => fitGlobe(host));
  }

  function fitGlobe(host: HTMLElement) {
    const stage = host.closest<HTMLElement>('[data-worldglyph-stage]');
    if (!stage) return;
    host.style.transform = 'none';
    host.style.marginLeft = '0';
    stage.style.height = 'auto';
    const avail = stage.clientWidth;
    const hb = host.getBoundingClientRect();
    let minL = hb.left, maxR = hb.right;
    host.querySelectorAll<HTMLElement>('.worldglyph-spot').forEach((s) => {
      const r = s.getBoundingClientRect();
      if (r.width) { minL = Math.min(minL, r.left); maxR = Math.max(maxR, r.right); }
    });
    const contentW = maxR - minL;
    if (contentW <= avail + 0.5) return;            // already fits
    const scale = avail / contentW;
    host.style.transformOrigin = 'top left';
    host.style.transform = `scale(${scale})`;
    // Center the true content (labels included) within the column.
    host.style.marginLeft = `${(avail - contentW * scale) / 2 - (minL - hb.left) * scale}px`;
    stage.style.height = `${host.offsetHeight * scale}px`;
  }

  const hosts = [...document.querySelectorAll<HTMLElement>('[data-worldglyph]')];
  hosts.forEach(initGlobe);

  new MutationObserver(() => hosts.forEach(initGlobe)).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  let rt: ReturnType<typeof setTimeout>;
  addEventListener('resize', () => {
    clearTimeout(rt);
    rt = setTimeout(() => hosts.forEach((h) => fitGlobe(h)), 150);
  });
</script>

<style>
  .worldglyph {
    margin: 0;
  }
  .worldglyph-stage {
    /* fitGlobe() scales the host to fit and sets this height to match.
       overflow:clip keeps the spinning globe from ever pushing the page wider
       than its column (a limb label can swing past the fit bounds mid-spin). */
    position: relative;
    overflow-x: clip;
  }
  .worldglyph-host {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: var(--ink-soft);
    cursor: grab;
    width: max-content;
    margin: 0 auto;
  }
  .worldglyph-host:active {
    cursor: grabbing;
  }
  .worldglyph-host :global(.worldglyph-spot) {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    white-space: nowrap;
    color: var(--red);
    background: var(--paper);
    padding: 0 3px;
    line-height: 1.4;
    height: auto !important;
    transition: opacity 0.18s ease;
  }
  .worldglyph-caption {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--hairline);
  }
</style>
