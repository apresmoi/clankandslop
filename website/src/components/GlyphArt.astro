---
/** Glyph-art illustrations rendered by the glyphcss engine (same renderer as
    the World Desk globe). `shape` picks the model:
      colosseum — the real coliseum.obj mesh, loaded + normalized, recoloured
                  to ink (the World Cup "fortress")
      play      — a built play triangle in a ring (YouTube / MrBeast)
    Draggable; idles with a slow spin that pauses on interaction / off-screen. */
interface Props {
  shape: 'colosseum' | 'play';
  caption?: string;
  cols?: number;
  rows?: number;
  rotX?: number;
  rotY?: number;
  rotZ?: number;
  zoom?: number;
  spin?: boolean;
}
const shape = Astro.props.shape;
const dflt = shape === 'play'
  ? { rotX: 0.52, rotY: 0.42, rotZ: 0.0, zoom: 0.46, spin: false }
  : { rotX: 1.12, rotY: 0.5, rotZ: 0.0, zoom: 0.4, spin: false };
const {
  caption = '',
  cols = 58, rows = 30,
  rotX = dflt.rotX, rotY = dflt.rotY, rotZ = dflt.rotZ, zoom = dflt.zoom,
  spin = dflt.spin,
} = Astro.props;
const src = shape === 'colosseum' ? '/models/coliseum.obj' : '';
const config = JSON.stringify({ shape, src, cols, rows, rotX, rotY, rotZ, zoom, spin });
---
<figure class="glyphart">
  <div class="glyphart-stage" data-glyphart-stage>
    <div class="glyphart-host" data-glyphart data-config={config}></div>
  </div>
  {caption && <figcaption class="glyphart-caption">{caption}</figcaption>}
</figure>

<script>
  import { createGlyphScene, createGlyphOrbitControls, createGlyphPerspectiveCamera, loadMesh, computeSceneBbox } from 'glyphcss';

  type V = [number, number, number];
  type Poly = { vertices: V[]; color?: string };

  const cvar = (n: string, f: string) => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f;
  const parseHex = (hex: string): [number, number, number] => {
    const h = hex.trim().replace('#', '');
    const v = h.length === 3 ? h.split('').map((c) => c + c).join('') : h;
    return [parseInt(v.slice(0, 2), 16), parseInt(v.slice(2, 4), 16), parseInt(v.slice(4, 6), 16)];
  };
  const mix = (a: string, b: string, t: number): string => {
    const [ar, ag, ab] = parseHex(a), [br, bg, bb] = parseHex(b);
    const c = (x: number, y: number) => Math.round(x + (y - x) * t).toString(16).padStart(2, '0');
    return `#${c(ar, br)}${c(ag, bg)}${c(ab, bb)}`;
  };

  // Center + scale a mesh to a 2-unit box, then optionally rotate it upright.
  function fitToUnitBbox(polys: Poly[], rotZdeg = 0): Poly[] {
    const bbox = computeSceneBbox(polys as any);
    const cx = (bbox.min[0] + bbox.max[0]) / 2, cy = (bbox.min[1] + bbox.max[1]) / 2, cz = (bbox.min[2] + bbox.max[2]) / 2;
    const size = Math.max(bbox.max[0] - bbox.min[0], bbox.max[1] - bbox.min[1], bbox.max[2] - bbox.min[2]) || 1;
    const k = 2 / size;
    return polys.map((p) => ({
      ...p,
      vertices: p.vertices.map((v): V => [(v[0] - cx) * k, (v[1] - cy) * k, (v[2] - cz) * k]),
    }));
  }

  // Push a quad/tri both ways so neither face is culled by view angle.
  function bothSides(polys: Poly[], v: V[], color: string) {
    polys.push({ vertices: v, color });
    polys.push({ vertices: [...v].reverse(), color });
  }
  // A bold, chunky play triangle (a triangular prism). Read at a 3/4 angle the
  // extruded faces give it clear form — a ring just muddied it in glyph.
  function buildPlay(ink: string, accent: string): Poly[] {
    const polys: Poly[] = [];
    const d = 0.5;
    const face = mix(accent, ink, 0.0);
    const side = mix(accent, ink, 0.5);
    const tri: [number, number][] = [[-0.62, -0.8], [-0.62, 0.8], [0.86, 0]];
    const front: V[] = tri.map(([x, y]) => [x, y, d]);
    const back: V[] = tri.map(([x, y]) => [x, y, -d]);
    bothSides(polys, front, face);
    bothSides(polys, back, face);
    for (let i = 0; i < 3; i++) { const j = (i + 1) % 3; bothSides(polys, [front[i], front[j], back[j], back[i]], side); }
    return polys;
  }

  const scenes = new Map<HTMLElement, { destroy(): void }>();

  async function initArt(host: HTMLElement) {
    scenes.get(host)?.destroy();
    host.innerHTML = '';
    const cfg = JSON.parse(host.dataset.config!);
    const ink = cvar('--ink', '#0F0F0F'), paper = cvar('--paper', '#F4EEE0'), accent = cvar('--accent', '#B8841E');
    const inkMix = mix(paper, ink, 0.82);

    let polys: Poly[];
    if (cfg.shape === 'colosseum') {
      const mesh = await loadMesh(cfg.src);
      // Recolour the model to ink — the form reads from glyph density, not the
      // mesh's own materials; keeps it in the paper's palette.
      polys = fitToUnitBbox(mesh.polygons as any).map((p) => ({ ...p, color: inkMix }));
    } else {
      polys = fitToUnitBbox(buildPlay(ink, accent));
    }

    const camera = createGlyphPerspectiveCamera({ rotX: cfg.rotX, rotY: cfg.rotY, zoom: cfg.zoom, distance: 100 });
    const scene = createGlyphScene(host, {
      mode: 'solid', cols: cfg.cols, rows: cfg.rows, cellAspect: 1.67, useColors: true, camera,
      directionalLight: { direction: [-0.45, -0.7, 0.6], intensity: 0.6 },
      ambientLight: { intensity: 0.55 },
    });
    scene.add(polys as any);

    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const controls = createGlyphOrbitControls(scene, {
      drag: true, wheel: false, invert: 1,
      animate: cfg.spin && !reduceMotion ? { speed: 0.22, axis: 'y', pauseOnInteraction: true } : false,
    });
    let io: IntersectionObserver | null = null;
    if (cfg.spin && !reduceMotion && 'IntersectionObserver' in window) {
      io = new IntersectionObserver(([e]) => { e.isIntersecting ? controls.resume() : controls.pause(); }, { threshold: 0 });
      io.observe(host);
    }
    scenes.set(host, { destroy: () => { io?.disconnect(); controls.destroy(); scene.destroy(); } });
    requestAnimationFrame(() => fitArt(host));
  }

  // Scale the render to fill its cell (contain: bounded by width or height,
  // whichever binds), centered both ways — so the illustration matches the
  // height of the text column beside it.
  function fitArt(host: HTMLElement) {
    const stage = host.closest<HTMLElement>('[data-glyphart-stage]');
    if (!stage) return;
    host.style.transform = 'none'; host.style.marginLeft = '0'; host.style.marginTop = '0';
    const aw = stage.clientWidth, ah = stage.clientHeight;
    const r = host.getBoundingClientRect();
    if (!r.width || !r.height || !aw) return;
    const scale = ah > 0 ? Math.min(aw / r.width, ah / r.height) : aw / r.width;
    host.style.transformOrigin = 'top left';
    host.style.transform = `scale(${scale})`;
    host.style.marginLeft = `${(aw - r.width * scale) / 2}px`;
    if (ah > 0) host.style.marginTop = `${Math.max(0, (ah - r.height * scale) / 2)}px`;
  }

  const hosts = [...document.querySelectorAll<HTMLElement>('[data-glyphart]')];
  hosts.forEach(initArt);
  if (hosts.length) {
    new MutationObserver(() => hosts.forEach(initArt)).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    let rt: ReturnType<typeof setTimeout>;
    addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => hosts.forEach(fitArt), 150); });
  }
</script>

<style>
  .glyphart { margin: 0; height: 100%; display: flex; flex-direction: column; }
  .glyphart-stage { position: relative; overflow: clip; flex: 1 1 auto; min-height: 0; }
  .glyphart-host {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: var(--ink-soft);
    width: max-content;
    cursor: grab;
  }
  .glyphart-host:active { cursor: grabbing; }
  .glyphart-caption {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--hairline);
    text-align: center;
  }
</style>
