---
/** Static glyph-art illustrations, compiled like the print map — no client JS,
    no shipped model. `shape` picks the art:
      colosseum — the coliseum.obj render, baked to ASCII by the glyphcss
                  rasterizer (scripts/bake-glyphart.mjs) and committed.
      play      — a play triangle in a ring, computed here.
    The <pre> fills its cell via container queries, so it matches the height of
    the text beside it. */
import coliseumAscii from '../data/glyphart-coliseum.txt?raw';
import playAscii from '../data/glyphart-play.txt?raw';

interface Props {
  shape: 'colosseum' | 'play';
  caption?: string;
}
const { shape, caption = '' } = Astro.props;

const art = (shape === 'colosseum' ? coliseumAscii : playAscii).replace(/\n+$/, '');
const lines = art.split('\n');
const cols = Math.max(...lines.map((l) => l.length));
const rows = lines.length;
---
<figure class={`glyphart glyphart-${shape}`} style={`--cols:${cols};--rows:${rows};`}>
  <div class="glyphart-stage">
    <pre class="glyphart-pre">{art}</pre>
  </div>
  {caption && <figcaption class="glyphart-caption">{caption}</figcaption>}
</figure>

<style>
  .glyphart { margin: 0; height: 100%; display: flex; flex-direction: column; }
  /* Mobile (stacked): no text beside it — fill the column width. */
  .glyphart-stage { flex: 1 1 auto; min-height: 0; container-type: inline-size; display: flex; }
  .glyphart-pre {
    font-family: var(--font-mono);
    font-size: calc(100cqw / (var(--cols) * 0.6));
    line-height: 1;
    white-space: pre;
    width: fit-content;
    margin: auto;
    color: var(--ink);
    letter-spacing: 0;
  }
  /* Desktop (side by side): the row stretches the cell to the text height, so
     the art is contained within it — the text is the height ceiling, never the
     other way round. A hair of slack (rows+1, 0.62) keeps it off the edges. */
  @media (min-width: 880px) {
    .glyphart-stage { container-type: size; }
    .glyphart-pre {
      font-size: min(calc(100cqw / (var(--cols) * 0.62)), calc(100cqh / (var(--rows) + 1)));
    }
  }
  .glyphart-play .glyphart-pre { color: var(--accent); }
  .glyphart-caption {
    flex: 0 0 auto;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
    text-align: center;
  }
</style>
