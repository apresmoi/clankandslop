---
/** Static glyph-art illustrations, compiled like the print map — no client JS,
    no shipped model. `shape` picks the art:
      colosseum — the coliseum.obj render, baked to ASCII by the glyphcss
                  rasterizer (scripts/bake-glyphart.mjs) and committed.
      play      — a play triangle in a ring, computed here.
    The <pre> fills its cell via container queries, so it matches the height of
    the text beside it. */
import coliseumAscii from '../data/glyphart-coliseum.txt?raw';
import playAscii from '../data/glyphart-play.txt?raw';
import notFoundAscii from '../data/glyphart-404.txt?raw';

interface Props {
  shape: 'colosseum' | 'play' | 'notfound';
  caption?: string;
}
const { shape, caption = '' } = Astro.props;

const sources: Record<string, string> = { colosseum: coliseumAscii, play: playAscii, notfound: notFoundAscii };
const art = (sources[shape] ?? coliseumAscii).replace(/\n+$/, '');
// When baked with useColors:true the art is HTML (color spans); else plain text.
// Size from the VISIBLE glyphs (tags stripped) so the cols/rows math is right.
const isColor = art.includes('<span');
const plain = isColor ? art.replace(/<[^>]+>/g, '') : art;
const lines = plain.split('\n');
const cols = Math.max(...lines.map((l) => l.length));
const rows = lines.length;
---
<figure class={`glyphart glyphart-${shape}${isColor ? ' glyphart-color' : ''}`} style={`--cols:${cols};--rows:${rows};`}>
  <div class="glyphart-stage">
    {isColor ? <pre class="glyphart-pre" set:html={art} /> : <pre class="glyphart-pre">{art}</pre>}
  </div>
  <figcaption class="glyphart-caption">
    {caption && <span class="glyphart-name">{caption}</span>}
    <a class="glyphart-credit" href="https://glyphcss.com" target="_blank" rel="noopener">glyphcss.com</a>
  </figcaption>
</figure>

<style>
  .glyphart { margin: 0; height: 100%; display: flex; flex-direction: column; }
  /* Mobile (stacked): no text beside it — fill the column width. */
  .glyphart-stage { flex: 1 1 auto; min-height: 0; container-type: inline-size; display: flex; }
  .glyphart-pre {
    font-family: var(--font-mono);
    font-size: calc(100cqw / (var(--cols) * 0.6));
    line-height: 1;
    white-space: pre;
    width: fit-content;
    margin: auto;
    color: var(--ink);
    letter-spacing: 0;
  }
  /* Desktop (side by side): the row stretches the cell to the text height, so
     the art is contained within it — the text is the height ceiling, never the
     other way round. A hair of slack (rows+1, 0.62) keeps it off the edges. */
  @media (min-width: 880px) {
    .glyphart-stage { container-type: size; }
    .glyphart-pre {
      font-size: min(calc(100cqw / (var(--cols) * 0.62)), calc(100cqh / (var(--rows) + 1)));
    }
  }
  .glyphart-play .glyphart-pre { color: var(--accent); }
  /* The 404 text is rasterized at cellAspect 1.28 (≈ 0.77/0.6) — render the
     <pre> at that line-height so the glyphs keep their baked proportions. */
  .glyphart-notfound .glyphart-pre { line-height: 0.77; }
  /* Light mode: sparse glyphs read faint on cream — bold them for ink coverage
     (monospace bold keeps the same advance width, so layout is unchanged). */
  :global([data-theme="light"]) .glyphart-pre { font-weight: 700; }
  .glyphart-caption {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
    text-align: center;
  }
  /* Tiny credit so readers learn the glyph art is glyphcss. */
  .glyphart-credit {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--muted);
    opacity: 0.7;
    text-decoration: none;
  }
  .glyphart-credit:hover { color: var(--accent); opacity: 1; }
</style>
