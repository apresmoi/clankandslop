---
/** Static glyph-art illustrations, compiled like the print map — no client JS,
    no shipped model. `shape` picks the art:
      colosseum — the coliseum.obj render, baked to ASCII by the glyphcss
                  rasterizer (scripts/bake-glyphart.mjs) and committed.
      play      — a play triangle in a ring, computed here.
    The <pre> fills its cell via container queries, so it matches the height of
    the text beside it. */
import coliseumAscii from '../data/glyphart-coliseum.txt?raw';

interface Props {
  shape: 'colosseum' | 'play';
  caption?: string;
}
const { shape, caption = '' } = Astro.props;

function buildPlay(): string {
  // W:H ≈ 1.67 so the ring reads round at the mono cell aspect.
  const W = 40, H = 24;
  const rows: string[] = [];
  for (let r = 0; r < H; r++) {
    let line = '';
    for (let c = 0; c < W; c++) {
      const nx = (c / (W - 1)) * 2 - 1;
      const ny = (r / (H - 1)) * 2 - 1;
      const d = Math.hypot(nx, ny);
      const ring = d <= 0.97 && d >= 0.82;
      const tri = nx >= -0.34 && nx <= 0.46 && Math.abs(ny) <= ((0.46 - nx) / 0.8) * 0.46;
      line += ring || tri ? '█' : ' ';
    }
    rows.push(line.replace(/\s+$/, ''));
  }
  return rows.join('\n');
}

const art = shape === 'colosseum' ? coliseumAscii.replace(/\n+$/, '') : buildPlay();
const lines = art.split('\n');
const cols = Math.max(...lines.map((l) => l.length));
const rows = lines.length;
---
<figure class={`glyphart glyphart-${shape}`} style={`--cols:${cols};--rows:${rows};`}>
  <div class="glyphart-stage">
    <pre class="glyphart-pre">{art}</pre>
  </div>
  {caption && <figcaption class="glyphart-caption">{caption}</figcaption>}
</figure>

<style>
  .glyphart { margin: 0; height: 100%; display: flex; flex-direction: column; }
  /* Mobile: stacked, the cell has no fixed height — fill the column width only
     (cqw). Desktop overrides below with container-type:size for height-match. */
  .glyphart-stage { flex: 1 1 auto; min-height: 0; container-type: inline-size; display: flex; }
  .glyphart-pre {
    font-family: var(--font-mono);
    font-size: calc(100cqw / (var(--cols) * 0.6));
    line-height: 1;
    white-space: pre;
    margin: auto;
    color: var(--ink);
    letter-spacing: 0;
  }
  /* Desktop: the row stretches the cell to the text height, so contain-fit
     (the binding axis) makes the illustration match that height. */
  @media (min-width: 880px) {
    .glyphart-stage { container-type: size; }
    .glyphart-pre { font-size: min(calc(100cqw / (var(--cols) * 0.6)), calc(100cqh / var(--rows))); }
  }
  .glyphart-play .glyphart-pre { color: var(--accent); }
  .glyphart-caption {
    flex: 0 0 auto;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--hairline);
    text-align: center;
  }
</style>
