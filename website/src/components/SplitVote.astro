---
interface AgentVote {
  name: string;
  p: number;
  why?: string;
  reputation?: number;
}
interface Props {
  question: string;
  meta?: string;
  yes: { count: string; agents: AgentVote[]; note?: string };
  no:  { count: string; agents: AgentVote[]; note?: string };
}
const { question, meta, yes, no } = Astro.props;

const minority = yes.agents.length <= no.agents.length ? yes : no;
const minoritySide = yes.agents.length <= no.agents.length ? 'YES' : 'NO';
const dissenters = minority.agents.map((a) => a.name).join(', ');
const dissentP = minority.agents.length === 1 ? minority.agents[0].p.toFixed(2) : null;
const tally = `${yes.count.split('/')[0].trim()} – ${no.count.split('/')[0].trim()}`;
---
<div class="splitvote">
  <div class="splitvote-head">
    <span class="splitvote-label">The Split Vote</span>
    <span class="splitvote-tally">{tally}</span>
    {dissenters && (
      <span class="splitvote-dissent">
        <span class="dim">dissent ·</span> {dissenters}
        {dissentP && <span class="dim"> ({minoritySide === 'YES' ? 'p' : 'p_no'} = {dissentP})</span>}
      </span>
    )}
    {meta && <span class="splitvote-meta">{meta}</span>}
  </div>
  <div class="splitvote-q">{question}</div>

  <div class="sv-bar" aria-hidden="true">
    <span class="sv-bar-yes" style={`flex:${yes.agents.length}`}></span>
    <span class="sv-bar-no"  style={`flex:${no.agents.length}`}></span>
  </div>

  <div class="sv-cols" style={`grid-template-columns:${yes.agents.length}fr ${no.agents.length}fr`}>
    <div class="sv-col sv-col-yes">
      <div class="sv-col-head"><span class="sv-side">Yes</span><span class="sv-count">{yes.count}</span></div>
      {yes.agents.map((a) => (
        <div class="sv-vote">
          <div class="sv-vote-top"><span class="sv-name">{a.name}</span><span class="sv-p">{a.p.toFixed(2)}</span></div>
          {a.why && <p class="sv-why">{a.why}</p>}
        </div>
      ))}
      {yes.note && <p class="sv-colnote">{yes.note}</p>}
    </div>
    <div class="sv-col sv-col-no">
      <div class="sv-col-head"><span class="sv-side">No</span><span class="sv-count">{no.count}</span></div>
      {no.agents.map((a) => (
        <div class="sv-vote">
          <div class="sv-vote-top"><span class="sv-name">{a.name}</span><span class="sv-p">{a.p.toFixed(2)}</span></div>
          {a.why && <p class="sv-why">{a.why}</p>}
        </div>
      ))}
      {no.note && <p class="sv-colnote">{no.note}</p>}
    </div>
  </div>
</div>

<style>
  .splitvote {
    margin: 28px 0;
    padding: 12px 0 14px;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
  }
  .splitvote-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 14px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .splitvote-label { font-weight: 700; color: var(--ink); }
  .splitvote-tally {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0;
    font-weight: 700;
    color: var(--accent);
    text-transform: none;
  }
  .splitvote-dissent {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink);
  }
  .splitvote-dissent .dim { color: var(--muted); }
  .splitvote-meta {
    margin-left: auto;
    font-size: 10px;
    color: var(--muted);
  }
  .splitvote-q {
    margin-top: 8px;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 17px;
    line-height: 1.35;
    color: var(--ink);
  }

  /* Proportional split bar — widths track the tally (e.g. 3 vs 2). */
  .sv-bar {
    display: flex;
    height: 4px;
    margin: 14px 0 4px;
    gap: 2px;
  }
  .sv-bar-yes { background: var(--accent); }
  .sv-bar-no  { background: var(--hairline-strong); }

  /* Proportional columns: the majority side is physically wider. */
  .sv-cols {
    display: grid;
    gap: 0 32px;
    margin-top: 14px;
  }
  .sv-col-no { padding-left: 32px; border-left: 1px solid var(--hairline); margin-left: -32px; }
  .sv-col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding-bottom: 8px;
    margin-bottom: 10px;
    border-bottom: 1.5px solid var(--ink);
  }
  .sv-col-yes .sv-side { color: var(--accent); }
  .sv-col-no  .sv-side { color: var(--muted); }
  .sv-count { color: var(--muted); font-weight: 500; }

  .sv-vote { margin-bottom: 12px; }
  .sv-vote:last-of-type { margin-bottom: 0; }
  .sv-vote-top { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
  .sv-name {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .sv-p {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
  }
  .sv-why {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 3px 0 0;
  }
  .sv-colnote {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 12.5px;
    color: var(--muted);
    margin: 12px 0 0;
    padding-top: 8px;
    border-top: 1px dotted var(--hairline);
  }

  @media (max-width: 640px) {
    .sv-cols { grid-template-columns: 1fr !important; gap: 0; }
    .sv-col-no { padding-left: 0; border-left: 0; margin-left: 0; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--hairline); }
  }
</style>
