---
interface Call {
  horizon: string;
  question: string;
  call: 'YES' | 'NO' | 'FLAT';
  direction: 'bull' | 'bear' | 'flat';
  p: number;
  interval?: number;
  quorum: string;
  detail?: string;
  dissent?: { agents: string[]; p: number };
}
interface Resolved {
  call: string;
  outcome: 'hit' | 'miss' | 'open';
  prior_p: number;
}
interface Props {
  meta?: string;
  open_calls: Call[];
  resolved?: Resolved[];
}
const { meta, open_calls, resolved } = Astro.props;

const arrowFor = (d: 'bull' | 'bear' | 'flat') => d === 'bull' ? '▲' : d === 'bear' ? '▼' : '↔';
---
<div class="ledger">
  <div class="ledger-head">
    <span class="ledger-label">The Forecast Ledger</span>
    {meta && <span class="ledger-meta">{meta}</span>}
  </div>

  <div class="ledger-colhead" aria-hidden="true">
    <span>Resolves</span>
    <span>Question · why</span>
    <span>Call</span>
    <span>Posterior</span>
    <span>Dissent</span>
  </div>

  <div class="ledger-rows">
    {open_calls.map((c) => (
      <div class="ledger-row">
        <span class="ledger-horizon">{c.horizon}</span>
        <div class="ledger-qcol">
          <span class="ledger-q">{c.question}</span>
          {c.detail && <span class="ledger-why">{c.detail}</span>}
        </div>
        <span class={`ledger-call ${c.direction}`}>{c.call}<span class="arrow">{arrowFor(c.direction)}</span></span>
        <div class="ledger-pcol">
          <span class="ledger-p">{c.p.toFixed(2)}{c.interval !== undefined && <span class="ledger-int"> ±{c.interval.toFixed(2)}</span>}</span>
          {c.quorum && <span class="ledger-quorum">{c.quorum} agree</span>}
        </div>
        <span class="ledger-dis">
          {c.dissent
            ? <><span class="dim">{c.dissent.agents.join(', ')}</span> {(c.dissent.p * 100).toFixed(0)}%</>
            : <span class="dim">—</span>}
        </span>
      </div>
    ))}
  </div>

  <p class="ledger-key">
    <strong>Posterior</strong> is the desk's probability the call resolves YES, with a ±1σ band;
    <strong>quorum</strong> is how many of five desk agents back it; <strong>dissent</strong> names the
    agent arguing the other side, with their counter-probability. Every call is scored against the
    outcome at the next bell — <a href="/about">how the paper computes its numbers</a>.
  </p>

  {resolved && resolved.length > 0 && (
    <div class="ledger-resolved">
      <span class="dim">Resolved · </span>
      {resolved.map((r, i) => (
        <span class="ledger-resolved-item">
          {r.call} <span class={r.outcome}>
            {r.outcome === 'hit' ? '✓' : r.outcome === 'miss' ? '✗' : '…'}
          </span><span class="dim"> p={r.prior_p.toFixed(2)}</span>{i < resolved.length - 1 ? <span class="dim"> · </span> : ''}
        </span>
      ))}
    </div>
  )}
</div>

<style>
  .ledger {
    margin: 28px 0;
    padding: 14px 0 10px;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
  }
  .ledger-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 11px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 6px;
  }
  .ledger-label { font-weight: 700; color: var(--ink); }
  .ledger-meta  { color: var(--muted); font-size: 10px; }

  .ledger-colhead {
    display: grid;
    grid-template-columns: 110px 1fr 70px 110px 120px;
    gap: 16px;
    padding: 6px 0;
    border-bottom: 1px solid var(--hairline-strong);
    font-family: var(--font-sans);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ledger-colhead span:nth-child(3) { text-align: left; }
  .ledger-colhead span:nth-child(4),
  .ledger-colhead span:nth-child(5) { text-align: left; }

  .ledger-rows { display: flex; flex-direction: column; }
  .ledger-row {
    display: grid;
    grid-template-columns: 110px 1fr 70px 110px 120px;
    align-items: start;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px dotted var(--hairline);
  }
  .ledger-row:last-child { border-bottom: none; }
  .ledger-qcol { display: flex; flex-direction: column; gap: 4px; }
  .ledger-why {
    font-family: var(--font-body);
    font-size: 12.5px;
    font-style: italic;
    line-height: 1.4;
    color: var(--muted);
  }
  .ledger-pcol { display: flex; flex-direction: column; gap: 3px; }
  .ledger-quorum {
    font-family: var(--font-sans);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ledger-key {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.5;
    color: var(--muted);
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--hairline);
  }
  .ledger-key strong { color: var(--ink-soft); font-weight: 700; font-style: normal; }
  .ledger-key a { color: var(--accent); text-decoration: none; border-bottom: 1px dotted var(--accent); }

  .ledger-horizon {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .ledger-q {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--ink);
    line-height: 1.4;
  }
  .ledger-call {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .ledger-call .arrow { margin-left: 4px; }
  .ledger-call.bull { color: var(--green); }
  .ledger-call.bear { color: var(--red); }
  .ledger-call.flat { color: var(--muted); }
  .ledger-p {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    font-weight: 500;
  }
  .ledger-int { color: var(--muted); font-weight: 400; }
  .ledger-dis {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    white-space: nowrap;
  }
  .ledger-dis .dim { color: var(--muted); }

  .ledger-resolved {
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--hairline);
    line-height: 1.6;
  }
  .ledger-resolved .hit  { color: var(--green); font-weight: 700; }
  .ledger-resolved .miss { color: var(--red);   font-weight: 700; text-decoration: line-through; }
  .ledger-resolved .open { color: var(--muted); }
  .ledger-resolved .dim  { color: var(--muted); }

  @media (max-width: 880px) {
    .ledger-colhead { display: none; }
    .ledger-row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "horizon call"
        "qcol    qcol"
        "pcol    dis";
      row-gap: 6px;
      align-items: baseline;
    }
    .ledger-horizon { grid-area: horizon; }
    .ledger-call    { grid-area: call; text-align: right; }
    .ledger-qcol    { grid-area: qcol; }
    .ledger-pcol    { grid-area: pcol; flex-direction: row; align-items: baseline; gap: 8px; }
    .ledger-dis     { grid-area: dis; text-align: right; }
  }
</style>
