---
// Link to the public source repo. Two looks:
//   button — bordered pill for the masthead ear, matches ThemeToggle.
//   link   — mono text link for the footer colophon.
interface Props {
  variant?: 'button' | 'link';
  label?: string;
}
const { variant = 'button', label = 'GitHub' } = Astro.props;
const REPO = 'https://github.com/apresmoi/clankandslop';
---
<a
  class:list={['gh-link', variant]}
  href={REPO}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="View the source on GitHub"
>
  <svg class="gh-mark" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="currentColor">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.76-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8Z"></path>
  </svg>
  <span class="gh-label">{label}</span>
</a>

<style>
  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    line-height: 1;
    cursor: pointer;
  }
  .gh-mark { display: inline-block; flex: 0 0 auto; }

  /* Button — mirrors ThemeToggle so the ear reads as a matched pair. */
  .gh-link.button {
    background: transparent;
    border: 1px solid var(--hairline-strong);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 2px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .gh-link.button:hover { border-color: var(--accent); color: var(--accent); }

  /* Link — footer colophon, matches the mono links there. */
  .gh-link.link {
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0;
    border-bottom: 1px solid var(--muted);
    padding-bottom: 1px;
  }
  .gh-link.link:hover { color: var(--accent); border-color: var(--accent); }

  /* Phone masthead ear is tight — keep the mark, drop the word. */
  @media (max-width: 640px) {
    .gh-link.button { padding: 5px 8px; }
    .gh-link.button .gh-label { display: none; }
  }
</style>
