---
interface Props {
  ascii: string;
  caption: string;
}
const { ascii, caption } = Astro.props;
---
<pre class="ascii-art">{ascii}</pre>
<div class="ascii-cap">▲ {caption}</div>

<style>
  .ascii-art {
    font-family: var(--font-mono);
    font-size: 11.5px;
    line-height: 0.95;
    white-space: pre;
    text-align: center;
    margin: 16px auto 4px;
    color: var(--ink);
    padding: 24px 18px;
    border-top: 4px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: transparent;
  }
  .ascii-cap {
    font-family: var(--font-sans);
    font-size: 10px;
    text-align: center;
    color: var(--muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0;
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--hairline);
  }

  @media (max-width: 600px) {
    .ascii-art { font-size: 8.5px; padding: 16px 8px; line-height: 0.95; }
  }
</style>
