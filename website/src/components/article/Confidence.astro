---
interface Props {
  label: string;
  value: number;
  interval?: number;
  revision: number;
  /** Edition date (YYYY-MM-DD) + last-revision time (e.g. "13:50 UTC") — the
      "… ago" is computed from these, never hand-authored. */
  editionDate: string;
  timestamp: string;
  nextUpdateUtc?: string;
}
const { label, value, interval, revision, editionDate, timestamp, nextUpdateUtc } = Astro.props;
const hm = (timestamp.match(/(\d{1,2}):(\d{2})/) ?? []);
const iso = hm.length ? `${editionDate}T${hm[1].padStart(2, '0')}:${hm[2]}:00Z` : '';
---
<div class="conf">
  <div class="conf-row">
    <span class="conf-label">{label}</span>
    <span class="conf-val">
      {value.toFixed(2)}{interval !== undefined && ` ± ${interval.toFixed(2)}`}
    </span>
  </div>
  <span class="rev">
    <strong>rev {revision}</strong> · <span data-since={iso}>updated {timestamp}</span>{nextUpdateUtc && ` · next ${nextUpdateUtc} UTC`}
  </span>
</div>

<script is:inline>
  // Compute "… ago" live from the revision timestamp — gracefully stepping to
  // hours / days / a date so a frozen edition never shows an absurd count.
  (() => {
    for (const el of document.querySelectorAll('[data-since]')) {
      const t = Date.parse(el.getAttribute('data-since') || '');
      if (Number.isNaN(t)) continue;
      const m = Math.floor((Date.now() - t) / 60000);
      el.textContent =
        m < 1 ? 'just now'
        : m < 60 ? `${m} min ago`
        : m < 1440 ? `${Math.floor(m / 60)}h ago`
        : m < 10080 ? `${Math.floor(m / 1440)}d ago`
        : new Date(t).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }
  })();
</script>

<style>
  .conf {
    margin: 12px 0;
    padding: 8px 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .conf-row { display: contents; }
  .conf-label { font-weight: 700; color: var(--ink); }
  .conf-val {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--accent);
    font-weight: 500;
  }
  .rev {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--muted);
  }
  .rev strong { color: var(--ink); font-weight: 500; }

  @media (max-width: 600px) {
    .conf {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      font-size: 9px;
      letter-spacing: 0.12em;
    }
  }
</style>
